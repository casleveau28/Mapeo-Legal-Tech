    <!-- INTERACTIVIDAD MEDIANTE JAVASCRIPT -->
    <script>
        // Función para cambiar de pestañas en el Formulario dinámicamente
        function switchTab(tabId) {
            // Manejo estético visual de botones
            const buttons = document.querySelectorAll('.tab-btn');
            buttons.forEach(btn => btn.classList.remove('active'));
            event.currentTarget.classList.add('active');

            // Cambio del texto informativo dinámico simulando la interacción UX del Canvas
            const instruction = document.getElementById('tab-instruction');
            if(tabId === 'datos') {
                instruction.innerText = "Mostrando campos transversales de identificación obligatorios para todos los perfiles de postulación.";
            } else if(tabId === 'profesionales') {
                instruction.innerText = "Perfil Investigadores: Habilita el requisito del Artículo Científico original o Ensayo de investigación técnica avanzada.";
            } else if(tabId === 'instituciones') {
                instruction.innerText = "Perfil Entidades Gubernamentales: Requiere adjuntar el Resumen Ejecutivo del proyecto enfocado en interoperabilidad o gestión digital.";
            } else if(tabId === 'empresas') {
                instruction.innerText = "Perfil Startups/Firmas: Requiere adjuntar la Arquitectura de la Solución comercial, métricas operativas verificables y kit de marca (.ZIP).";
            }
        }

        // Sistema interactivo de Acordeón para las FAQ
        document.querySelectorAll('.faq-question').forEach(item => {
            item.addEventListener('click', () => {
                const parent = item.parentElement;
                const isOpen = parent.classList.contains('open');
                
                // Cierra los demás antes de abrir el actual
                document.querySelectorAll('.faq-item').forEach(child => child.classList.remove('open'));
                
                if (!isOpen) {
                    parent.classList.add('open');
                }
            });
        });
    </script>
</body>
</html>
